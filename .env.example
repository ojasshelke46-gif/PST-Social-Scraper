# Apify — datadoping/linkedin-posts-search-scraper (LinkedIn data source)
APIFY_TOKEN=

# Anakin Search API (https://api.anakin.io/v1) — used for X/Twitter post discovery
ANAKIN_API_KEY=

# Optional: override Anakin API base URL (defaults to https://api.anakin.io/v1)
# ANAKIN_BASE_URL=https://api.anakin.io/v1

# Default keyword the dashboard searches for
NEXT_PUBLIC_DEFAULT_KEYWORD=Next.js
