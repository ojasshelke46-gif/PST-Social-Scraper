# Apify — datadoping/linkedin-posts-search-scraper (LinkedIn data source)
APIFY_TOKEN=

# TwitterAPI.io — advanced search (X/Twitter data source)
TWITTERAPI_IO_KEY=

# Default keyword the dashboard searches for
NEXT_PUBLIC_DEFAULT_KEYWORD=Next.js

# Firebase — client-side SDK (Auth)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase — Admin SDK (Firestore server-side writes)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
